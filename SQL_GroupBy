SELECT * FROM products;

#This will return the total quantity of all products in stock.
select sum(quantityInStock) from products;

#COUNT(quantityInStock) = total number of rows in the table
select count(quantityInStock) from products;

#Counts all rows in the table
SELECT COUNT(*) FROM products;

#Counts only rows where productName is NOT NULL
SELECT COUNT(productName) FROM products;

#For each product category, calculate total quantity available.
select productLine ,sum(quantityInStock) from products
group by productLine;

#For each product category, calculate total items and total cost.
select productLine ,sum(quantityInStock),sum(buyprice) from products
group by productLine;

#For each product category and each vendor, calculate total items and total cost.
select productLine ,productvendor,sum(quantityInStock),sum(buyprice) 
from products
group by productLine,productvendor;

#Group by category and vendor, calculate totals, and sort results by product category.
select productLine ,productvendor,sum(quantityInStock),sum(buyprice) 
from products
group by productLine,productvendor
order by productLine;

#For each product category and vendor, show number of products, total cost, and average cost.
select productLine ,productvendor,count(quantityInStock),sum(buyprice),avg(buyprice)
from products
group by productLine,productvendor;

#For each product line, show the highest price, lowest price, and average price of products.
#MAX(buyPrice) → most expensive product in the category
#MIN(buyPrice) → cheapest product in the category
#AVG(buyPrice) → average price of all products in the category
select productLine ,max(buyprice),min(buyprice),avg(buyprice)
from products
group by productLine;

# Filter the data in productLine like planes,ships.
SELECT productLine, AVG(buyPrice), MAX(buyprice), MIN(buyPrice)
FROM products
WHERE productLine IN ('Planes', 'Ships')
GROUP BY productLine;

